{
  "name": "@chordially/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e .env -- tsx watch src/server.ts",
    "build": "dotenv -e .env.example -- prisma generate && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "dotenv -e .env.example -- prisma generate && eslint src",
    "typecheck": "dotenv -e .env.example -- prisma generate && tsc -p tsconfig.json --noEmit",
    "test": "dotenv -e .env.test -- prisma generate && dotenv -e .env.test -- prisma db push --skip-generate --accept-data-loss && dotenv -e .env.test -- vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@chordially/shared": "workspace:*",
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^2.4.3",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.13.10",
    "@types/supertest": "^6.0.2",
    "dotenv-cli": "^7.4.4",
    "prisma": "^6.5.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
